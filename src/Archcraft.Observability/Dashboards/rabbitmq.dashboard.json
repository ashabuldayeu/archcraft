{
  "id": null,
  "uid": "rabbitmq-SERVICE_NAME",
  "title": "SERVICE_NAME — RabbitMQ",
  "schemaVersion": 38,
  "refresh": "5s",
  "time": { "from": "now-15m", "to": "now" },
  "annotations": {
    "list": [
      {
        "builtIn": 1,
        "datasource": { "type": "grafana", "uid": "-- Grafana --" },
        "enable": true,
        "hide": false,
        "iconColor": "rgba(0, 211, 255, 1)",
        "name": "Archcraft Events",
        "type": "tags",
        "tags": ["archcraft"]
      }
    ]
  },
  "panels": [
    {
      "id": 1,
      "type": "stat",
      "title": "Queues Online",
      "gridPos": { "h": 4, "w": 4, "x": 0, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "count(rabbitmq_queue_messages{job=\"SERVICE_NAME-exporter\"})",
          "legendFormat": "queues"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 2,
      "type": "stat",
      "title": "Messages Ready",
      "gridPos": { "h": 4, "w": 4, "x": 4, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 1000 }, { "color": "red", "value": 10000 }] },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rabbitmq_queue_messages_ready{job=\"SERVICE_NAME-exporter\"})",
          "legendFormat": "ready"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 3,
      "type": "stat",
      "title": "Messages Unacknowledged",
      "gridPos": { "h": 4, "w": 4, "x": 8, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "green", "value": 0 }, { "color": "yellow", "value": 100 }, { "color": "red", "value": 1000 }] },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rabbitmq_queue_messages_unacknowledged{job=\"SERVICE_NAME-exporter\"})",
          "legendFormat": "unacked"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 4,
      "type": "stat",
      "title": "Consumers",
      "gridPos": { "h": 4, "w": 4, "x": 12, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum(rabbitmq_queue_consumers{job=\"SERVICE_NAME-exporter\"})",
          "legendFormat": "consumers"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 5,
      "type": "stat",
      "title": "Connections",
      "gridPos": { "h": 4, "w": 4, "x": 16, "y": 0 },
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "thresholds": { "mode": "absolute", "steps": [{ "color": "red", "value": 0 }, { "color": "green", "value": 1 }] },
          "mappings": []
        }
      },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rabbitmq_connectionsTotal{job=\"SERVICE_NAME-exporter\"}",
          "legendFormat": "connections"
        }
      ],
      "options": { "reduceOptions": { "calcs": ["lastNotNull"] }, "colorMode": "background" }
    },
    {
      "id": 6,
      "type": "timeseries",
      "title": "Publish Rate (msg/s)",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "msgps", "min": 0 } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (queue) (rate(rabbitmq_queue_messages_published_total{job=\"SERVICE_NAME-exporter\"}[1m]))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 7,
      "type": "timeseries",
      "title": "Deliver Rate (msg/s)",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 4 },
      "fieldConfig": { "defaults": { "unit": "msgps", "min": 0 } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (queue) (rate(rabbitmq_queue_messages_delivered_total{job=\"SERVICE_NAME-exporter\"}[1m]))",
          "legendFormat": "{{queue}}"
        }
      ]
    },
    {
      "id": 8,
      "type": "timeseries",
      "title": "Queue Depth",
      "gridPos": { "h": 8, "w": 12, "x": 0, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "short", "min": 0 } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "sum by (queue) (rabbitmq_queue_messages{job=\"SERVICE_NAME-exporter\"})",
          "legendFormat": "{{queue}} total"
        },
        {
          "datasource": "Prometheus",
          "expr": "sum by (queue) (rabbitmq_queue_messages_ready{job=\"SERVICE_NAME-exporter\"})",
          "legendFormat": "{{queue}} ready"
        }
      ]
    },
    {
      "id": 9,
      "type": "timeseries",
      "title": "Consumer Utilisation",
      "gridPos": { "h": 8, "w": 12, "x": 12, "y": 12 },
      "fieldConfig": { "defaults": { "unit": "percentunit", "min": 0, "max": 1 } },
      "targets": [
        {
          "datasource": "Prometheus",
          "expr": "rabbitmq_queue_consumer_utilisation{job=\"SERVICE_NAME-exporter\"}",
          "legendFormat": "{{queue}}"
        }
      ]
    }
  ]
}
