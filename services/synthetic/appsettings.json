{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "SynteticApi": {
    "ServiceName": "syntetic-api",
    "Endpoints": [
      {
        "Alias": "checkout",
        "Pipeline": [
          {
            "Operation": "redis-call",
            "NotFoundRate": 0.3,
            "Fallback": [
              {
                "Operation": "pg-call"
              }
            ]
          },
          {
            "Operation": "http-call",
            "Target": "payment-service"
          }
        ]
      },
      {
        "Alias": "orders",
        "Pipeline": [
          {
            "Operation": "pg-call"
          }
        ]
      }
    ]
  }
}
